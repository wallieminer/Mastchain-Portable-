<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.MastChainStatsFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="#0A0E14">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:clipToPadding="false">

            <!-- ==================== HEADER ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp">

                <View
                    android:id="@+id/online_dot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginEnd="8dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MastChain Dashboard"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#E6EAF0" />

                    <TextView
                        android:id="@+id/header_station_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Station WallieM3"
                        android:textSize="13sp"
                        android:textColor="#8A94A6" />
                </LinearLayout>

                <TextView
                    android:id="@+id/header_status_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFFLINE"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#E5484D"
                    android:background="@drawable/mc_status_badge"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
            </LinearLayout>

            <!-- ==================== UPTIME ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#121821"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPTIME"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#8A94A6"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:paddingTop="4dp">

                        <TextView
                            android:id="@+id/uptime_percent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:textColor="#29C46A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="% today"
                            android:textSize="14sp"
                            android:textColor="#8A94A6"
                            android:paddingStart="4dp"
                            android:paddingBottom="6dp" />
                    </LinearLayout>

                    <!-- Uptime bar: 288 slots represented by a grid -->
                    <LinearLayout
                        android:id="@+id/uptime_bar_container"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/uptime_note"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="online = push every minute, regardless of ships"
                        android:textSize="11sp"
                        android:textColor="#8A94A6"
                        android:fontFamily="sans-serif-condensed" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== LIVE RECEPTION ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#121821"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIVE RECEPTION"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#8A94A6"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/rx_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#00C2D1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Messages"
                                android:textSize="10sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/rx_vessels"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#00C2D1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vessels"
                                android:textSize="10sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/rx_ch_a"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#E6EAF0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ch A"
                                android:textSize="10sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/rx_ch_b"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#E6EAF0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ch B"
                                android:textSize="10sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/rx_msg_min"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#E6EAF0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="msg/min"
                                android:textSize="10sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== LOCATION & HEX ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#121821"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOCATION &amp; HEX"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#8A94A6"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/loc_latlon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="15sp"
                                android:textColor="#E6EAF0" />

                            <TextView
                                android:id="@+id/loc_accuracy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="11sp"
                                android:textColor="#8A94A6" />

                            <TextView
                                android:id="@+id/loc_fix_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="11sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="H3 res-5"
                                android:textSize="10sp"
                                android:textColor="#8A94A6" />

                            <TextView
                                android:id="@+id/loc_h3_hex"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:textColor="#F26A1B" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== HEX COVERAGE ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#121821"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEX COVERAGE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#8A94A6"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/hex_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No hex data yet"
                        android:textSize="13sp"
                        android:textColor="#E6EAF0"
                        android:paddingTop="8dp"
                        android:fontFamily="monospace" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end"
                        android:paddingTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Est. tMAST today: "
                            android:textSize="12sp"
                            android:textColor="#8A94A6" />

                        <TextView
                            android:id="@+id/hex_tmast_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.000"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#F26A1B" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== UPLOAD ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#121821"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPLOAD"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#8A94A6"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/upload_sent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#29C46A" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sent"
                                android:textSize="10sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/upload_failed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#E5484D" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Failed"
                                android:textSize="10sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/upload_last"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#E6EAF0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Last Upload"
                                android:textSize="10sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/upload_endpoint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="api.mastchain.io"
                        android:textSize="11sp"
                        android:textColor="#8A94A6"
                        android:paddingTop="6dp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== BOND & WITHDRAWAL ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#121821"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BOND &amp; WITHDRAWAL"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#8A94A6"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="A minimum bond of 10 tMAST is required per station. Withdrawal to ERC-20 wallet is only available after the bond requirement is met. Check your balance on the MastChain Dashboard."
                        android:textSize="13sp"
                        android:textColor="#E6EAF0"
                        android:paddingTop="8dp"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== TOGGLES ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#121821"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Community Share Toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌐 Community Share"
                                android:textSize="15sp"
                                android:textColor="#E6EAF0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="See ships from aiscatcher.org"
                                android:textSize="12sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/community_share_toggle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#232C3A"
                        android:layout_marginBottom="8dp" />

                    <!-- MastChain Feed Toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⛓ MastChain Feed"
                                android:textSize="15sp"
                                android:textColor="#E6EAF0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Send AIS data to MastChain API"
                                android:textSize="12sp"
                                android:textColor="#8A94A6" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/mastchain_feed_toggle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ==================== OPEN DASHBOARD BUTTON ==================== -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/open_dashboard_button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Open MastChain Dashboard"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:backgroundTint="#F26A1B"
                app:cornerRadius="10dp"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="6dp" />

            <!-- Reset Stats (subtle) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/reset_stats_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Reset Stats"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:strokeColor="#232C3A"
                app:cornerRadius="10dp"
                android:textColor="#8A94A6"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>